{
  "name": "vat-validation",
  "version": "3.0.0-beta.1",
  "description": "Check the validity of the format of an EU VAT number",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prettier": "prettier --write 'src/**/*.ts'",
    "prettier:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src/ && tsc --noEmit",
    "prepare": "husky"
  },
  "license": "MIT",
  "keywords": [
    "vat-validation",
    "EU",
    "vat",
    "VAT",
    "VATIN",
    "european",
    "euro",
    "value",
    "added",
    "check",
    "syntax",
    "validator",
    "VAT Code validator",
    "validator",
    "finance",
    "tax"
  ],
  "ignore": {},
  "author": "",
  "contributors": [
    "Wilgert Velinga <wilgert@wilgert.nl> (http://wilgert.nl)"
  ],
  "private": false,
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "30.0.0",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "prettier": "3.8.1",
    "pretty-quick": "4.2.2",
    "ts-jest": "29.4.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@1.22.22"
}
